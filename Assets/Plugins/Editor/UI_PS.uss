/* Base style for the D-pad rectangles 
    height: 100px;
    position: relative;
}*/
/*TRANSFERED*/
.trigger-fill {
    width: 100px;
    height: 0px;
    bottom: 0;        
    left: 0;
    background-color: white;
    border-radius: 8px;
    position: absolute;
}
/*TRANSFERED*/
.dpad-btn {
    position: absolute;
    background-color: #333;
    /*border-radius: 4px;*/ /* Slight rounding for a plastic look */
    width: 30px;
    height: 50px;
}
/*TRANSFERED*/
/* Vertical Rectangles (Up/Down) */
.up-pad {
    rotate: 0deg;
    translate: 0 -35px; /* Moves it up from the center */
    border-radius: 5px 5px 15px 15px;
    border-width: 2px;
    border-color: black;
}
/*TRANSFERED*/
.down-pad {
    rotate: 0deg;
    translate: 0 35px;  /* Moves it down from the center */
    border-radius: 15px 15px 5px 5px;
     border-width: 2px;
    border-color: black;
}
/*TRANSFERED*/
/* Horizontal Rectangles (Left/Right) */
.left-pad {
    /* We swap width/height logic by rotating a vertical rectangle */
    rotate: 90deg; 
    translate: -35px 0; /* Moves it left from the center */
    border-radius: 15px 15px 5px 5px;
     border-width: 2px;
    border-color: black;
}
/*TRANSFERED*/
.right-pad {
    rotate: 90deg;
    translate: 35px 0;  /* Moves it right from the center */
    border-radius: 5px 5px 15px 15px;
     border-width: 2px;
    border-color: black;
}
