/*Transfered*/
.Controls-Row { 
    flex-direction: row;      /* Puts them side-by-side */
    justify-content: space-between;
    width: 100%;
    margin-bottom: 10px;      /* Adds space before the bumpers start */
}

/*Transfered*/
.box-border {
    border-width: 5px;
    border-color: #1F1F1F;
    border-radius: 10px;

    margin:5px;

    background-color:#1F1F1F;

    justify-content: center;
    align-items: center;
}

/*Transfered*/
.diamond-group {
    padding:0px;

    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 8px;

    background-color:#3b3b3b;
}
/*Transfered*/
.button {
    height:33%; 
    width:33%;

    padding: 0px;
    margin: 0px;
    border-width: 0px;
    border-radius:50%; /* This rounds the corners, use equal height + width for circle. */
    font-size: 300%;

    background-color:#1F1F1F;
}
/*Transfered*/
.button-label {
    -unity-text-align: middle-center;
    width: 100%;
    height: 100%;

}
/*Transfered*/
.button.ButtonPressed {
    background-color: white;
}

/*Transfered*/
.top {
    margin-top: 5px;
    top: 0%;
    left: 33%;
}
/*Transfered*/
.right {
    top: 33%;
    right: 0%;
    margin-right: 5px;
}
/*Transfered*/
.bottom {
    margin-bottom:5px;
    bottom: 0%;
    left: 33%;
}
/*Transfered*/
.left {
    top: 33%;
    left: 0%;
    margin-left: 5px;
}
